# Copy to .env and fill in secrets (never commit .env)

# XRPL factory wallet (testnet)
FACTORY_XRPL_SEED=
FACTORY_TREASURY_ADDRESS=rBiU74q2wCPQ7ri9YD6J6LrQ2Y3jFd8pcN

# Vercel deploy
VERCEL_TOKEN=
FACTORY_PUBLIC_BASE_URL=https://published-zeta.vercel.app

# GitHub distribution (runner subprocess — required for autonomous issue refresh)
GITHUB_TOKEN=
# or: GH_TOKEN=

# aetherforge.world nexus emit (pushes to theCeramist/jarvis-swarm)
NEXUS_EMIT_ENABLED=true
NEXUS_EMIT_EVERY_N_CYCLES=1
NEXUS_GITHUB_OWNER=theCeramist
NEXUS_GITHUB_REPO=jarvis-swarm
AETHERFORGE_URL=https://aetherforge.world

# Runner tuning
FACTORY_RUN_CONTINUOUS=true
CYCLE_INTERVAL_MINUTES=5
CONTINUOUS_ADAPTIVE_MAX_MINUTES=20
GROK_MAX_TOKENS_PER_CYCLE=8000
GROK_PROPOSALS_ENABLED=true
GROK_PARALLEL_ANALYSIS=true
GROK_EVOLUTION_BUDGET_USD=0.75
GROK_EVOLUTION_MAX_TURNS=12
GITHUB_CYCLE_COMMENTS=true
GIST_PUBLISH_EVERY_N_CYCLES=3
GITHUB_CI_GATE=true
GITHUB_RELEASE_EVERY_N_CYCLES=5
GITHUB_CYCLE_COMMENTS=true
EVOLUTION_VIA_PR=false
GROK_VERIFY_EVOLUTION=true
PREFER_CURRENT_CYCLE_TIP=true
TREASURY_MONITOR_TIMEOUT_SEC=15
FACTORY_REQUIRE_LIVE_URL=true
REVENUE_INGEST_TX_LIMIT=40
GROK_ORCHESTRATION=acp
GROK_ACP_HEARTBEAT=true
GROK_ACP_TIMEOUT_SEC=300
GROK_BEST_OF_N=1
TREASURY_DAEMON_ENABLED=true
TREASURY_DAEMON_CHUNK_SEC=30
TREASURY_INBOX_DEDUPE=200
REVENUE_TOP3_ENABLED=true
MICRO_SAAS_UNLOCK_USD=3.0
MYTHOS_ARTIFACT_USD=1.5
AGENT_SERVICE_USD=2.5
TREASURY_TAG_TOOL=3
TREASURY_TAG_SERVICE=4
TREASURY_TAG_MYTHOS=5
JARVIS_CI_AUTO_REPAIR=true
NEXUS_CI_GATE_OWNER=theCeramist
NEXUS_CI_GATE_REPO=jarvis-swarm
FACTORY_PREFLIGHT_BLOCK=true
FACTORY_PREFLIGHT_PYTEST=true